{
  "ready": false,
  "plugin_id": "etsy",
  "name": "Etsy",
  "description": "Manage listings, orders, and shops via the Etsy Open API v3.",
  "category": "ecommerce",
  "category_name": "E-Commerce",
  "category_icon": "🛒",
  "icon_uri": "🧶",
  "plugin_type": 1,
  "version": "1.0.0",
  "author": "OpenJiuwen",
  "tags": ["ecommerce", "etsy", "marketplace", "handmade", "listings", "orders"],
  "api_prefix": "https://openapi.etsy.com/v3",
  "documentation": "https://developers.etsy.com/documentation",
  "desc_mk": "Interact with the Etsy Open API v3 to manage shop listings, orders, transactions, and shop information.",
  "authentication": {
    "type": "api_key",
    "required_credentials": [
      {
        "name": "x-api-key",
        "env_var": "ETSY_API_KEY"
      }
    ]
  },
  "tools": [
    {
      "name": "get_shop",
      "description": "Retrieve details of an Etsy shop by shop ID.",
      "method": "GET",
      "path": "/application/shops/{shop_id}",
      "request_params": {
        "shop_id": {
          "type": "integer",
          "desc": "The unique numeric ID of the Etsy shop.",
          "is_required": true,
          "send_method": "Path"
        }
      }
    },
    {
      "name": "list_listings",
      "description": "Retrieve a list of active listings from an Etsy shop.",
      "method": "GET",
      "path": "/application/shops/{shop_id}/listings/active",
      "request_params": {
        "shop_id": {
          "type": "integer",
          "desc": "The unique numeric ID of the Etsy shop.",
          "is_required": true,
          "send_method": "Path"
        },
        "limit": {
          "type": "integer",
          "desc": "Number of results to return (max 100, default 25).",
          "is_required": false,
          "send_method": "Query"
        },
        "offset": {
          "type": "integer",
          "desc": "Number of results to skip.",
          "is_required": false,
          "send_method": "Query"
        },
        "sort_on": {
          "type": "string",
          "desc": "Sort field: created, price, updated, or score.",
          "is_required": false,
          "send_method": "Query"
        },
        "sort_order": {
          "type": "string",
          "desc": "Sort direction: asc or desc.",
          "is_required": false,
          "send_method": "Query"
        }
      }
    },
    {
      "name": "get_listing",
      "description": "Retrieve a single listing by its ID.",
      "method": "GET",
      "path": "/application/listings/{listing_id}",
      "request_params": {
        "listing_id": {
          "type": "integer",
          "desc": "The unique numeric ID of the listing.",
          "is_required": true,
          "send_method": "Path"
        }
      }
    },
    {
      "name": "create_draft_listing",
      "description": "Create a new draft listing in an Etsy shop.",
      "method": "POST",
      "path": "/application/shops/{shop_id}/listings",
      "request_params": {
        "shop_id": {
          "type": "integer",
          "desc": "The unique numeric ID of the Etsy shop.",
          "is_required": true,
          "send_method": "Path"
        },
        "quantity": {
          "type": "integer",
          "desc": "Number of items available for sale.",
          "is_required": true,
          "send_method": "Body"
        },
        "title": {
          "type": "string",
          "desc": "Title of the listing (max 140 characters).",
          "is_required": true,
          "send_method": "Body"
        },
        "description": {
          "type": "string",
          "desc": "Full description of the listing.",
          "is_required": true,
          "send_method": "Body"
        },
        "price": {
          "type": "number",
          "desc": "Listing price in the shop's default currency.",
          "is_required": true,
          "send_method": "Body"
        },
        "who_made": {
          "type": "string",
          "desc": "Who made the item: i_did, someone_else, or collective.",
          "is_required": true,
          "send_method": "Body"
        },
        "when_made": {
          "type": "string",
          "desc": "When was the item made (e.g. made_to_order, 2020_2024, before_2020).",
          "is_required": true,
          "send_method": "Body"
        },
        "taxonomy_id": {
          "type": "integer",
          "desc": "Numeric ID for the listing's category taxonomy node.",
          "is_required": true,
          "send_method": "Body"
        },
        "shipping_profile_id": {
          "type": "integer",
          "desc": "The numeric ID of the shipping profile for the listing.",
          "is_required": false,
          "send_method": "Body"
        },
        "tags": {
          "type": "array",
          "desc": "Array of tag strings for the listing (max 13 tags).",
          "is_required": false,
          "send_method": "Body"
        }
      }
    },
    {
      "name": "update_listing",
      "description": "Update an existing listing in an Etsy shop.",
      "method": "PATCH",
      "path": "/application/shops/{shop_id}/listings/{listing_id}",
      "request_params": {
        "shop_id": {
          "type": "integer",
          "desc": "The unique numeric ID of the Etsy shop.",
          "is_required": true,
          "send_method": "Path"
        },
        "listing_id": {
          "type": "integer",
          "desc": "The unique numeric ID of the listing to update.",
          "is_required": true,
          "send_method": "Path"
        },
        "title": {
          "type": "string",
          "desc": "Updated listing title.",
          "is_required": false,
          "send_method": "Body"
        },
        "description": {
          "type": "string",
          "desc": "Updated listing description.",
          "is_required": false,
          "send_method": "Body"
        },
        "price": {
          "type": "number",
          "desc": "Updated listing price.",
          "is_required": false,
          "send_method": "Body"
        },
        "quantity": {
          "type": "integer",
          "desc": "Updated quantity available.",
          "is_required": false,
          "send_method": "Body"
        },
        "state": {
          "type": "string",
          "desc": "Listing state: active, inactive, or draft.",
          "is_required": false,
          "send_method": "Body"
        }
      }
    },
    {
      "name": "list_shop_receipts",
      "description": "Retrieve a list of receipts (orders) from an Etsy shop.",
      "method": "GET",
      "path": "/application/shops/{shop_id}/receipts",
      "request_params": {
        "shop_id": {
          "type": "integer",
          "desc": "The unique numeric ID of the Etsy shop.",
          "is_required": true,
          "send_method": "Path"
        },
        "limit": {
          "type": "integer",
          "desc": "Number of results to return (max 100, default 25).",
          "is_required": false,
          "send_method": "Query"
        },
        "offset": {
          "type": "integer",
          "desc": "Number of results to skip.",
          "is_required": false,
          "send_method": "Query"
        },
        "was_paid": {
          "type": "boolean",
          "desc": "Filter to only return paid receipts.",
          "is_required": false,
          "send_method": "Query"
        },
        "was_shipped": {
          "type": "boolean",
          "desc": "Filter to only return shipped receipts.",
          "is_required": false,
          "send_method": "Query"
        }
      }
    },
    {
      "name": "get_shop_receipt",
      "description": "Retrieve a single receipt (order) by its ID.",
      "method": "GET",
      "path": "/application/shops/{shop_id}/receipts/{receipt_id}",
      "request_params": {
        "shop_id": {
          "type": "integer",
          "desc": "The unique numeric ID of the Etsy shop.",
          "is_required": true,
          "send_method": "Path"
        },
        "receipt_id": {
          "type": "integer",
          "desc": "The unique numeric ID of the receipt.",
          "is_required": true,
          "send_method": "Path"
        }
      }
    },
    {
      "name": "list_shop_reviews",
      "description": "Retrieve a list of reviews for an Etsy shop.",
      "method": "GET",
      "path": "/application/shops/{shop_id}/reviews",
      "request_params": {
        "shop_id": {
          "type": "integer",
          "desc": "The unique numeric ID of the Etsy shop.",
          "is_required": true,
          "send_method": "Path"
        },
        "limit": {
          "type": "integer",
          "desc": "Number of results to return (max 100, default 25).",
          "is_required": false,
          "send_method": "Query"
        },
        "offset": {
          "type": "integer",
          "desc": "Number of results to skip.",
          "is_required": false,
          "send_method": "Query"
        }
      }
    }
  ]
}
