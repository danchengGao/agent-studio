        }
      }
    },
    {
      "name": "get_onecall_weather",
      "path": "/onecall",
      "method": "GET",
      "description": "One Call API 3.0 - Current weather, minute forecast for 1 hour, hourly for 48 hours, daily for 8 days, alerts - requires subscription",
      "request_params": {
        "lat": {
          "type": "number",
          "description": "Latitude coordinate",
          "required": true,
          "send_method": "query"
        },
        "lon": {
          "type": "number",
          "description": "Longitude coordinate",
          "required": true,
          "send_method": "query"
        },
        "exclude": {
          "type": "string",
          "description": "Exclude parts: 'current', 'minutely', 'hourly', 'daily', 'alerts' (comma-separated)",
          "required": false,
          "send_method": "query"
        },
        "units": {
          "type": "string",
          "description": "Units: 'standard', 'metric', 'imperial'",
          "required": false,
          "send_method": "query",
          "default": "metric"
        },
        "lang": {
          "type": "string",
          "description": "Language code",
          "required": false,
          "send_method": "query",
          "default": "en"
        },
        "appid": {
          "type": "string",
          "description": "API key for authentication",
          "required": true,
          "send_method": "query"
        }
      }
    },
    {
      "name": "get_weather_alerts",
      "path": "/onecall",
      "method": "GET",
      "description": "Get government weather alerts for a location (severe weather warnings, advisories)",
      "request_params": {
        "lat": {
          "type": "number",
          "description": "Latitude coordinate",
          "required": true,
          "send_method": "query"
        },
        "lon": {
          "type": "number",
