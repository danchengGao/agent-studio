          "required": true,
          "send_method": "query"
        }
      }
    },
    {
      "name": "geocoding_direct",
      "path": "/geo/1.0/direct",
      "method": "GET",
      "description": "Convert city name to geographic coordinates (latitude and longitude)",
      "request_params": {
        "q": {
          "type": "string",
          "description": "City name, state code, country code (e.g., 'London,UK')",
          "required": true,
          "send_method": "query"
        },
        "limit": {
          "type": "integer",
          "description": "Number of locations in response (max 5)",
          "required": false,
          "send_method": "query",
          "default": 5
        },
        "appid": {
          "type": "string",
          "description": "API key for authentication",
          "required": true,
          "send_method": "query"
        }
      }
    },
    {
      "name": "geocoding_reverse",
      "path": "/geo/1.0/reverse",
      "method": "GET",
      "description": "Convert geographic coordinates to location name (reverse geocoding)",
      "request_params": {
        "lat": {
          "type": "number",
          "description": "Latitude coordinate",
          "required": true,
          "send_method": "query"
        },
        "lon": {
          "type": "number",
          "description": "Longitude coordinate",
          "required": true,
          "send_method": "query"
        },
        "limit": {
          "type": "integer",
          "description": "Number of locations in response",
          "required": false,
          "send_method": "query",
          "default": 5
        },
        "appid": {
          "type": "string",
