{
  "ready": false,
  "plugin_id": "qweather",
  "name": "QWeather API",
  "description": "Professional weather data service with global coverage. Real-time weather, forecasts, air quality, weather warnings, and minute-level precipitation for 200,000+ cities worldwide.",
  "category": "data",
  "category_name": "Data & Analytics",
  "category_icon": "📊",
  "icon_uri": "🌤️",
  "plugin_type": 1,
  "version": "1.0.0",
  "author": "OpenJiuwen",
  "tags": [
    "weather",
    "forecast",
    "air-quality",
    "climate",
    "meteorology"
  ],
  "api_prefix": "https://devapi.qweather.com",
  "desc_mk": "QWeather (和风天气) provides professional weather data services for developers worldwide. Access real-time weather, forecasts up to 30 days, air quality (AQI), severe weather warnings, minute-level precipitation, typhoon tracking, and historical weather data. **Note:** Requires API key from [QWeather Developer Platform](https://dev.qweather.com/). For production, use custom API host format: `https://{your-key}.api.qweather.com`",
  "header_configuration": {
    "API Key": {
      "type": "string",
      "send_method": "Header",
      "value": "QWEATHER_API_KEY",
      "description": "QWeather API key from QWeather Developer Platform"
    }
  },
  "tools": [
    {
      "name": "Real-time Weather",
      "path": "/v7/weather/now",
      "method": "GET",
      "description": "Get current real-time weather conditions for a location",
      "request_params": {
        "location": {
          "type": "string",
          "description": "Location ID, coordinates (lon,lat), or city name (e.g., '101010100' for Beijing, '116.41,39.92')",
          "required": true,
          "send_method": "Query"
        },
        "key": {
          "type": "string",
          "description": "QWeather API key (Environment variable: QWEATHER_API_KEY)",
          "required": true,
          "send_method": "Query"
        },
        "lang": {
          "type": "string",
          "description": "Language: 'zh' (Chinese), 'en' (English), 'ja', 'ko', 'fr', 'de', etc.",
          "required": false,
          "default": "en",
          "send_method": "Query"
        },
        "unit": {
          "type": "string",
          "description": "Unit system: 'm' (metric), 'i' (imperial)",
          "required": false,
          "default": "m",
          "send_method": "Query"
        }
      }
    },
    {
      "name": "Daily Weather Forecast (3 days)",
      "path": "/v7/weather/3d",
      "method": "GET",
      "description": "Get 3-day daily weather forecast",
      "request_params": {
        "location": {
          "type": "string",
          "description": "Location ID or coordinates",
          "required": true,
          "send_method": "Query"
