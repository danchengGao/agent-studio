{
  "ready": false,
  "plugin_id": "lastfm_api",
  "name": "Last.fm",
  "description": "Music tracking and discovery service. Scrobble tracks, get music recommendations, explore artist info, and discover similar music.",
  "category": "entertainment",
  "category_name": "Entertainment & Events",
  "category_icon": "🎭",
  "icon_uri": "📻",
  "plugin_type": 1,
  "version": "1.0.0",
  "author": "OpenJiuwen",
  "tags": [
    "music",
    "scrobbling",
    "lastfm",
    "recommendations",
    "discovery",
    "entertainment"
  ],
  "api_prefix": "https://ws.audioscrobbler.com/2.0",
  "desc_mk": "Last.fm is a music community and discovery platform that tracks your listening habits, provides personalized recommendations, and connects you with similar music lovers. This plugin provides access to artist info, track scrobbling, user data, and music charts.",
  "header_configuration": {
    "Content-Type": {
      "type": "string",
      "send_method": "Header",
      "value": "application/json",
      "description": "JSON content type header"
    }
  },
  "tools": [
    {
      "name": "Search Artist",
      "path": "/",
      "method": "GET",
      "description": "Search for an artist by name",
      "request_params": {
        "method": {
          "type": "string",
          "description": "API method name",
          "required": true,
          "default": "artist.search",
          "send_method": "Query"
        },
        "artist": {
          "type": "string",
          "description": "Artist name to search for",
          "required": true,
          "send_method": "Query"
        },
        "api_key": {
          "type": "string",
          "description": "Last.fm API key",
          "required": true,
          "send_method": "Query"
        },
        "format": {
          "type": "string",
          "description": "Response format",
          "required": false,
          "default": "json",
          "send_method": "Query"
        },
        "limit": {
          "type": "integer",
          "description": "Number of results per page",
          "required": false,
          "default": 30,
          "send_method": "Query"
        }
      }
    },
