    },
    {
      "name": "Get On Demand Page",
      "path": "/ondemand/pages/{ondemand_id}",
      "method": "GET",
      "description": "Get information about a specific On Demand page",
      "request_params": {
        "ondemand_id": {
          "type": "string",
          "description": "Vimeo On Demand page ID",
          "required": true,
          "send_method": "Path"
        }
      }
    }
  ]
}