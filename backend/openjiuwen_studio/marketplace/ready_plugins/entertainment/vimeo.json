          "required": false,
          "default": 1,
          "send_method": "Query"
        }
      }
    },
    {
      "name": "Get User Following",
      "path": "/users/{user_id}/following",
      "method": "GET",
      "description": "Get all users that a specific user is following",
      "request_params": {
        "user_id": {
          "type": "string",
          "description": "Vimeo user ID or 'me' for authenticated user",
          "required": true,
          "send_method": "Path"
        },
        "per_page": {
          "type": "integer",
          "description": "Number of users per page (1-100)",
          "required": false,
          "default": 25,
          "send_method": "Query"
        },
        "page": {
          "type": "integer",
          "description": "Page number",
          "required": false,
          "default": 1,
