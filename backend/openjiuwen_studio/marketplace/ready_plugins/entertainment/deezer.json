          "required": true,
          "send_method": "Path"
        },
        "limit": {
          "type": "integer",
          "description": "Number of albums to return",
          "required": false,
          "default": 25,
          "send_method": "Query"
        }
      }
    },
    {
      "name": "Get Artist Related",
      "path": "/artist/{artist_id}/related",
      "method": "GET",
      "description": "Get related artists",
      "request_params": {
        "artist_id": {
          "type": "string",
          "description": "Deezer artist ID",
          "required": true,
          "send_method": "Path"
        },
        "limit": {
          "type": "integer",
          "description": "Number of artists to return",
          "required": false,
          "default": 25,
          "send_method": "Query"
        }
      }
    },
    {
      "name": "Get Playlist",
      "path": "/playlist/{playlist_id}",
      "method": "GET",
      "description": "Get detailed information about a playlist",
      "request_params": {
        "playlist_id": {
          "type": "string",
          "description": "Deezer playlist ID",
          "required": true,
          "send_method": "Path"
        }
      }
    },
    {
      "name": "Get Playlist Tracks",
      "path": "/playlist/{playlist_id}/tracks",
      "method": "GET",
      "description": "Get all tracks from a playlist",
      "request_params": {
        "playlist_id": {
          "type": "string",
