{
  "ready": true,
  "plugin_id": "deezer_api",
  "name": "Deezer",
  "description": "Global music streaming service. Search tracks, albums, artists, playlists, and access a vast catalog of music from around the world.",
  "category": "entertainment",
  "category_name": "Entertainment & Events",
  "category_icon": "🎭",
  "icon_uri": "🎶",
  "plugin_type": 1,
  "version": "1.0.0",
  "author": "OpenJiuwen",
  "tags": [
    "music",
    "streaming",
    "deezer",
    "audio",
    "playlist",
    "entertainment"
  ],
  "api_prefix": "https://api.deezer.com",
  "desc_mk": "Deezer is a music streaming service with access to millions of songs. This plugin provides access to search functionality, track information, artist data, album details, and playlist management.",
  "header_configuration": {
    "Content-Type": {
      "type": "string",
      "send_method": "Header",
      "value": "application/json",
      "description": "JSON content type header"
    }
  },
  "tools": [
    {
      "name": "Search",
      "path": "/search",
      "method": "GET",
      "description": "Search for tracks on Deezer",
      "request_params": {
        "q": {
          "type": "string",
          "description": "Search query",
          "required": true,
          "send_method": "Query"
        },
        "limit": {
          "type": "integer",
          "description": "Number of results to return (max 100)",
          "required": false,
          "default": 25,
          "send_method": "Query"
        },
        "index": {
          "type": "integer",
          "description": "Index of the first item to return",
          "required": false,
          "default": 0,
          "send_method": "Query"
        },
        "strict": {
          "type": "string",
          "description": "Enable strict search mode (on/off)",
          "required": false,
          "send_method": "Query"
        }
      }
    },
    {
      "name": "Search Albums",
      "path": "/search/album",
      "method": "GET",
      "description": "Search specifically for albums",
      "request_params": {
        "q": {
          "type": "string",
          "description": "Search query",
          "required": true,
          "send_method": "Query"
        },
        "limit": {
          "type": "integer",
          "description": "Number of results",
          "required": false,
          "default": 25,
          "send_method": "Query"
        }
      }
    },
    {
      "name": "Search Artists",
      "path": "/search/artist",
      "method": "GET",
      "description": "Search specifically for artists",
      "request_params": {
        "q": {
          "type": "string",
          "description": "Search query",
          "required": true,
          "send_method": "Query"
        },
        "limit": {
          "type": "integer",
          "description": "Number of results",
          "required": false,
          "default": 25,
          "send_method": "Query"
        }
      }
    },
    {
      "name": "Search Playlists",
      "path": "/search/playlist",
      "method": "GET",
      "description": "Search specifically for playlists",
      "request_params": {
        "q": {
          "type": "string",
          "description": "Search query",
          "required": true,
          "send_method": "Query"
        },
        "limit": {
          "type": "integer",
          "description": "Number of results",
          "required": false,
          "default": 25,
          "send_method": "Query"
        }
      }
    },
    {
      "name": "Get Track",
      "path": "/track/{track_id}",
      "method": "GET",
      "description": "Get detailed information about a track",
      "request_params": {
        "track_id": {
          "type": "string",
          "description": "Deezer track ID",
          "required": true,
          "send_method": "Path"
        }
      }
    },
    {
      "name": "Get Album",
      "path": "/album/{album_id}",
      "method": "GET",
      "description": "Get detailed information about an album",
      "request_params": {
        "album_id": {
          "type": "string",
          "description": "Deezer album ID",
          "required": true,
          "send_method": "Path"
        }
      }
    },
    {
      "name": "Get Album Tracks",
      "path": "/album/{album_id}/tracks",
      "method": "GET",
      "description": "Get all tracks from an album",
      "request_params": {
        "album_id": {
          "type": "string",
          "description": "Deezer album ID",
          "required": true,
          "send_method": "Path"
        },
        "limit": {
          "type": "integer",
          "description": "Number of tracks to return",
          "required": false,
          "default": 25,
          "send_method": "Query"
        }
      }
    },
    {
      "name": "Get Artist",
      "path": "/artist/{artist_id}",
      "method": "GET",
      "description": "Get detailed information about an artist",
      "request_params": {
        "artist_id": {
          "type": "string",
          "description": "Deezer artist ID",
          "required": true,
          "send_method": "Path"
        }
      }
    },
    {
      "name": "Get Artist Top Tracks",
      "path": "/artist/{artist_id}/top",
      "method": "GET",
      "description": "Get an artist's top tracks",
      "request_params": {
        "artist_id": {
          "type": "string",
          "description": "Deezer artist ID",
          "required": true,
          "send_method": "Path"
        },
        "limit": {
          "type": "integer",
          "description": "Number of tracks to return",
          "required": false,
          "default": 25,
          "send_method": "Query"
        }
      }
    },
    {
