{
  "ready": true,
  "plugin_id": "alpaca_data",
  "name": "Alpaca Data",
  "description": "Real-time and historical market data API for stocks, options, crypto, forex, and news. Access OHLCV bars, quotes, trades, snapshots, and corporate actions.",
  "category": "finance",
  "category_name": "Finance & Trading",
  "category_icon": "📊",
  "icon_uri": "📈",
  "plugin_type": 1,
  "version": "1.0.0",
  "author": "OpenJiuwen",
  "tags": [
    "stocks",
    "market-data",
    "finance",
    "real-time",
    "historical",
    "options",
    "crypto",
    "forex",
    "news"
  ],
  "api_prefix": "https://data.alpaca.markets/v2",
  "documentation": "https://docs.alpaca.markets/",
  "desc_mk": "Alpaca Data API provides real-time and historical market data for stocks, options, cryptocurrencies, and forex. Access OHLCV candlestick data, quotes, trades, orderbooks, and corporate actions. Supports multiple data feeds including IEX, SIP, and OTC. **Free tier** available with IEX data. Get API keys at [Alpaca Markets](https://app.alpaca.markets/paper/dashboard/overview).",
  "header_configuration": {
    "APCA-API-KEY-ID": {
      "value": "YOUR_ALPACA_API_KEY_ID",
      "description": "Alpaca API Key ID (Environment variable: APCA_API_KEY_ID)"
    },
    "APCA-API-SECRET-KEY": {
      "value": "YOUR_ALPACA_SECRET_KEY",
      "description": "Alpaca API Secret Key (Environment variable: APCA_API_SECRET_KEY)"
    }
  },
  "tools": [
    {
      "name": "Get Stock Bars",
      "path": "/stocks/bars",
      "method": "GET",
      "description": "Get historical OHLCV bar data for multiple stocks over a specified time range with customizable timeframe",
      "request_params": {
        "symbols": {
          "type": "string",
          "description": "Comma-separated list of stock symbols (e.g., 'AAPL,TSLA,MSFT')",
          "required": true,
          "send_method": "Query"
        },
        "timeframe": {
          "type": "string",
          "description": "Bar timeframe: '1Min', '5Min', '15Min', '1H', '1D', '1W', '1M'",
          "required": true,
          "default": "1D",
          "send_method": "Query"
        },
        "start": {
          "type": "string",
          "description": "Start date in ISO 8601 format (e.g., '2024-01-01T00:00:00Z')",
          "required": true,
          "send_method": "Query"
        },
        "end": {
          "type": "string",
          "description": "End date in ISO 8601 format (e.g., '2024-12-31T23:59:59Z')",
          "required": false,
          "send_method": "Query"
        },
        "limit": {
          "type": "integer",
          "description": "Maximum number of bars per symbol (1-10000)",
          "required": false,
          "default": 1000,
          "send_method": "Query"
        },
        "adjustment": {
          "type": "string",
          "description": "Price adjustment: 'raw', 'split', 'dividend', 'all'",
          "required": false,
          "default": "raw",
          "send_method": "Query"
        },
        "currency": {
          "type": "string",
          "description": "Currency of prices: 'USD' (default) or 'CAD'",
          "required": false,
          "default": "USD",
          "send_method": "Query"
        },
        "feed": {
          "type": "string",
          "description": "Data feed: 'IEX', 'SIP', 'OTC'",
          "required": false,
          "default": "IEX",
          "send_method": "Query"
        }
      }
    },
