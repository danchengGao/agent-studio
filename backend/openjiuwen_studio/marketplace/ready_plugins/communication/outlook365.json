{
  "ready": false,
  "plugin_id": "outlook365_api",
  "name": "Outlook 365 API",
  "description": "Microsoft Outlook 365 email and calendar API via Microsoft Graph. Send emails, manage inbox, handle contacts, calendar events, and meetings through the Microsoft 365 ecosystem.",
  "category": "communication",
  "category_name": "Communication",
  "category_icon": "📞",
  "icon_uri": "📮",
  "plugin_type": 1,
  "version": "1.0.0",
  "author": "OpenJiuwen",
  "tags": [
    "email",
    "outlook",
    "microsoft365",
    "calendar",
    "microsoft"
  ],
  "api_prefix": "https://graph.microsoft.com/v1.0",
  "documentation": "https://learn.microsoft.com/en-us/graph/api/resources/mail-api-overview",
  "desc_mk": "Microsoft Outlook 365 API via Microsoft Graph provides access to email, calendar, and contacts for Microsoft 365 users. Supports reading, sending, organizing emails and managing calendar events.",
  "authentication": {
    "type": "bearer",
    "required_credentials": [
      {
        "name": "Access Token",
        "env_var": "MICROSOFT_GRAPH_ACCESS_TOKEN",
        "description": "Microsoft Graph OAuth2 access token with Mail.ReadWrite, Mail.Send, and Calendars.ReadWrite permissions"
      }
    ]
  },
  "tools": [
    {
      "name": "List Messages",
      "path": "/me/messages",
      "method": "GET",
      "description": "Get messages from the authenticated user's mailbox",
      "request_params": {
        "$top": {
          "type": "integer",
          "description": "Maximum number of messages to return (default: 10, max: 100)",
          "required": false,
          "default": 10,
          "send_method": "Query"
        },
        "$filter": {
          "type": "string",
          "description": "OData filter expression (e.g., 'isRead eq false')",
          "required": false,
          "send_method": "Query"
        },
        "$search": {
          "type": "string",
          "description": "Search query string (e.g., '\"meeting\" AND from:boss@company.com')",
          "required": false,
          "send_method": "Query"
        },
        "$orderby": {
          "type": "string",
          "description": "Sort order (e.g., 'receivedDateTime desc')",
          "required": false,
          "default": "receivedDateTime desc",
          "send_method": "Query"
        },
        "$select": {
          "type": "string",
          "description": "Comma-separated list of properties to return",
          "required": false,
          "send_method": "Query"
        }
      }
    },
    {
      "name": "Get Message",
      "path": "/me/messages/{id}",
      "method": "GET",
      "description": "Get a specific message by ID",
      "request_params": {
        "id": {
          "type": "string",
          "description": "Message ID",
          "required": true,
          "is_path_param": true
        }
      }
    },
    {
      "name": "Send Email",
      "path": "/me/sendMail",
      "method": "POST",
      "description": "Send an email message",
      "request_params": {
        "message": {
          "type": "object",
          "description": "Message object with subject, body (contentType, content), toRecipients, ccRecipients, bccRecipients",
          "required": true,
          "send_method": "Body"
        },
        "saveToSentItems": {
          "type": "boolean",
          "description": "Save message to Sent Items folder (default: true)",
          "required": false,
          "default": true,
          "send_method": "Body"
        }
      }
    },
    {
      "name": "Reply to Message",
      "path": "/me/messages/{id}/reply",
      "method": "POST",
      "description": "Reply to an email message",
      "request_params": {
        "id": {
          "type": "string",
          "description": "ID of the message to reply to",
          "required": true,
          "is_path_param": true
        },
        "message": {
          "type": "object",
          "description": "Reply message object with body and toRecipients",
          "required": false,
          "send_method": "Body"
        },
        "comment": {
          "type": "string",
          "description": "Reply comment text",
          "required": false,
          "send_method": "Body"
        }
      }
    },
    {
      "name": "Move Message",
      "path": "/me/messages/{id}/move",
      "method": "POST",
      "description": "Move a message to a different folder",
      "request_params": {
        "id": {
          "type": "string",
          "description": "Message ID to move",
          "required": true,
          "is_path_param": true
        },
        "destinationId": {
          "type": "string",
          "description": "Destination folder ID or well-known folder name (inbox, drafts, sentitems, deleteditems, junk)",
          "required": true,
          "send_method": "Body"
        }
      }
    },
    {
      "name": "Delete Message",
      "path": "/me/messages/{id}",
      "method": "DELETE",
      "description": "Delete a message",
      "request_params": {
        "id": {
          "type": "string",
          "description": "Message ID to delete",
          "required": true,
          "is_path_param": true
        }
      }
    },
    {
      "name": "List Mail Folders",
      "path": "/me/mailFolders",
      "method": "GET",
      "description": "List all mail folders in the user's mailbox",
      "request_params": {
        "$top": {
          "type": "integer",
          "description": "Maximum number of folders to return",
          "required": false,
          "default": 50,
          "send_method": "Query"
        }
      }
    },
    {
      "name": "List Calendar Events",
      "path": "/me/events",
      "method": "GET",
      "description": "Get events from the user's default calendar",
      "request_params": {
        "$top": {
          "type": "integer",
          "description": "Maximum number of events to return",
          "required": false,
          "default": 10,
          "send_method": "Query"
        },
        "$filter": {
          "type": "string",
          "description": "OData filter (e.g., 'start/dateTime ge 2024-01-01T00:00:00Z')",
          "required": false,
          "send_method": "Query"
        },
        "$orderby": {
          "type": "string",
          "description": "Sort order for events",
          "required": false,
          "default": "start/dateTime asc",
          "send_method": "Query"
        }
      }
    },
    {
      "name": "Create Calendar Event",
      "path": "/me/events",
      "method": "POST",
      "description": "Create a new calendar event or meeting",
      "request_params": {
        "subject": {
          "type": "string",
          "description": "Event subject/title",
          "required": true,
          "send_method": "Body"
        },
        "body": {
          "type": "object",
          "description": "Event body with contentType (HTML or Text) and content",
          "required": false,
          "send_method": "Body"
        },
        "start": {
          "type": "object",
          "description": "Start time object with dateTime (ISO 8601) and timeZone fields",
          "required": true,
          "send_method": "Body"
        },
        "end": {
          "type": "object",
          "description": "End time object with dateTime (ISO 8601) and timeZone fields",
          "required": true,
          "send_method": "Body"
        },
        "attendees": {
          "type": "array",
          "description": "Array of attendee objects with emailAddress and type (required/optional)",
          "required": false,
          "send_method": "Body"
        },
        "location": {
          "type": "object",
          "description": "Location object with displayName",
          "required": false,
          "send_method": "Body"
        },
        "isOnlineMeeting": {
          "type": "boolean",
          "description": "Create as Teams online meeting",
          "required": false,
          "default": false,
          "send_method": "Body"
        }
      }
    }
  ]
}
