{
  "name": "check_balance",
  "desc": "查询余额工作流，可根据用户名称查询账户当前余额",
  "icon_uri": "",
  "url": "test",
  "schema": {
    "nodes": [
      {
        "id": "start_0",
        "type": "1",
        "meta": { "position": { "x": 180, "y": 38 } },
        "data": {
          "title": "开始",
          "outputs": {
            "type": "object",
            "properties": {
              "query": { "type": "string", "default": "你好，请帮我分析一下这个问题。" }
            }
          }
        }
      },
      {
        "id": "questioner_0",
        "type": "7",
        "meta": { "position": { "x": 640, "y": 38 } },
        "data": {
          "title": "提问器",
          "inputs": {
            "inputParameters": {
              "query": {
                "type": "ref",
                "content": ["start_0", "query"],
                "extra": { "index": 0 }
              }
            },
            "llmParam": {
              "systemPrompt": {
                "type": "template",
                "content": ""
              },
              "prompt": {
                "type": "template",
                "content": ""
              }
            },
            "max_response": 10
          },
          "outputs": {
            "type": "object",
            "properties": {
              "user_response": { "type": "string", "description": "用户响应输出变量" },
              "account_name": { "type": "string", "description": "用户名称" }
            },
            "required": ["user_response", "account_name"]
          }
        }
      },
      {
        "id": "end_0",
        "type": "2",
        "meta": { "position": { "x": 1100, "y": 38 } },
        "data": {
          "title": "结束",
          "inputs": {
            "inputParameters": {
              "result": {
                "type": "ref",
                "content": ["questioner_0", "account_name"],
                "extra": { "index": 0 }
              }
            },
            "streaming": true,
            "content": {
              "type": "template",
              "content": "已完成{{result}}的余额查询!"
            }
          }
        }
      }
    ],
    "edges": [
      { "sourceNodeID": "questioner_0", "targetNodeID": "end_0" },
      { "sourceNodeID": "start_0", "targetNodeID": "questioner_0" }
    ]
  }
}
