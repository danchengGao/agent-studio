          "data": {
            "title": "Check for code fix",
            "inputs": {
              "inputParameters": {
                "input": {
                  "type": "ref",
                  "content": [
                    "loop_CSHMa_locals",
                    "recommendationsArray"
                  ],
                  "extra": {
                    "index": 0
                  }
                }
              },
              "language": "python",
              "code": "import re\n\ndef main(args):\n    try:\n        params = args.params\n        text = params.get(\"input\", \"\") if isinstance(params, dict) else \"\"\n        \n        if not text:\n            return {\n                \"Has_code_fix\": False,\n                \"Diff\": \"\",\n                \"Filename\": \"\"\n            }\n        \n        # Normalize escaped newlines to actual newlines\n        text = text.replace('\\\\n', '\\n')\n        \n        diff_start = text.find(\"```diff\")\n        if diff_start == -1:\n            return {\n                \"Has_code_fix\": False,\n                \"Diff\": \"\",\n                \"Filename\": \"\"\n            }\n        \n        content_start = diff_start + 7\n        diff_end = text.find(\"```\", content_start)\n        \n        if diff_end == -1:\n            return {\n                \"Has_code_fix\": False,\n                \"Diff\": \"\",\n                \"Filename\": \"\"\n            }\n        \n        diff_text = text[content_start:diff_end].strip()\n        \n        # Common file extensions\n        ext = r'\\.(py|js|ts|jsx|tsx|java|cpp|c|h|hpp|go|rs|rb|php|swift|kt|scala|sh|bash|yml|yaml|json|xml|html|css|sql|md|txt)'\n        \n        # Extract filename from diff header or surrounding text\n        filename = \"\"\n        \n        # Try diff header formats (within the diff itself)\n        diff_patterns = [\n            r'^[-+]{3} [ab]/(.+?' + ext + r')',  # --- a/file.py or +++ b/file.py\n            r'^diff --git a/(.+?' + ext + r')',   # diff --git a/file.py b/file.py\n            r'^Index: (.+?' + ext + r')',          # SVN style\n        ]\n        \n        for pattern in diff_patterns:\n            match = re.search(pattern, diff_text, re.MULTILINE)\n            if match:\n                filename = match.group(1)\n                break\n        \n        # Fallback: look in the full text for various filename patterns\n        if not filename:\n            text_patterns = [\n                r'\\*\\*File:\\s*(.+?' + ext + r')\\*\\*',  # **File: filename.py**\n                r'File:\\s*(.+?' + ext + r')',          # File: filename.py\n                r'in `([^`]+' + ext + r')`',           # in `filename.py`\n                r'file `([^`]+' + ext + r')`',         # file `filename.py`\n            ]\n            \n            for pattern in text_patterns:\n                match = re.search(pattern, text)\n                if match:\n                    filename = match.group(1)\n                    break\n        \n        return {\n            \"Has_code_fix\": True,\n            \"Diff\": diff_text,\n            \"Filename\": filename\n        }\n    \n    except Exception as e:\n        return {\n            \"Has_code_fix\": False,\n            \"Diff\": \"\",\n            \"Filename\": \"\"\n        }"
            },
