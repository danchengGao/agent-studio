              "language": "python",
              "code": "def main(args):\n    params = args.params if hasattr(args, \"params\") else {}\n    \n    # Get LLM output\n    llm_output = params.get(\"LLMOutput\", \"\") or \"\"\n    \n    # Get filename \n    filename = params.get(\"Filename\", \"\") or \"\"\n    \n    # Check if we should write\n    output_stripped = llm_output.strip()\n    write_file = (\n        output_stripped != \"NO_CHANGES_NEEDED\" \n        and output_stripped != \"\" \n        and len(output_stripped) > 100\n    )\n    \n    return {\n        \"writeFile\": bool(write_file),\n        \"NewContent\": llm_output if write_file else \"\",\n        \"Filename\": filename\n    }"
            },
