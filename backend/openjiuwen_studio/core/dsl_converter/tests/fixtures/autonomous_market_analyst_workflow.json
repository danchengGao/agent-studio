            {
              "id": "code_compute_indicators",
              "type": "10",
              "meta": {"position": {"x": 600, "y": 50}},
              "data": {
                "title": "Compute Technical Indicators",
                "inputs": {
                  "inputParameters": {
                    "market_response": {"type": "ref", "content": ["http_fetch_market_data", "response"]},
                    "ticker": {"type": "ref", "content": ["5_a4d5361d", "items"]}
                  },
                  "language": "python3",
                  "code": "import json\nimport statistics\n\ndef compute_rsi(prices, period=14):\n    if len(prices) < period + 1:\n        return 50.0\n    deltas = [prices[i] - prices[i-1] for i in range(1, len(prices))]\n    gains = [d if d > 0 else 0 for d in deltas]\n    losses = [-d if d < 0 else 0 for d in deltas]\n    avg_gain = sum(gains[-period:]) / period\n    avg_loss = sum(losses[-period:]) / period\n    if avg_loss == 0:\n        return 100.0\n    rs = avg_gain / avg_loss\n    return round(100 - (100 / (1 + rs)), 2)\n\ndef compute_macd(prices, fast=12, slow=26, signal=9):\n    if len(prices) < slow:\n        return {'macd': 0, 'signal': 0, 'histogram': 0}\n    ema_fast = prices[-1] * (2/(fast+1)) + prices[-fast] * (1 - 2/(fast+1))\n    ema_slow = prices[-1] * (2/(slow+1)) + prices[-slow] * (1 - 2/(slow+1))\n    macd = ema_fast - ema_slow\n    signal_line = macd * (2/(signal+1))\n    return {'macd': round(macd, 2), 'signal': round(signal_line, 2), 'histogram': round(macd - signal_line, 2)}\n\ndef main(market_response, ticker):\n    try:\n        data = market_response if isinstance(market_response, dict) else json.loads(str(market_response))\n        chart_data = data.get('chart', {}).get('result', [{}])[0]\n        quote = chart_data.get('indicators', {}).get('quote', [{}])[0]\n        close_prices = [p for p in quote.get('close', []) if p is not None]\n        volumes = [v for v in quote.get('volume', []) if v is not None]\n        if len(close_prices) < 2:\n            return {'error': 'Insufficient data', 'ticker': ticker}\n        cur = close_prices[-1]\n        ma_20 = sum(close_prices[-20:]) / min(20, len(close_prices))\n        ma_50 = sum(close_prices[-50:]) / min(50, len(close_prices))\n        momentum_5d = ((cur / close_prices[-6]) - 1) * 100 if len(close_prices) >= 6 else 0\n        returns = [(close_prices[i] / close_prices[i-1] - 1) for i in range(1, len(close_prices))]\n        volatility = statistics.stdev(returns) * 100 if len(returns) > 1 else 0\n        return {\n            'ticker': ticker,\n            'current_price': round(cur, 2),\n            'ma_20': round(ma_20, 2),\n            'ma_50': round(ma_50, 2),\n            'rsi_14': compute_rsi(close_prices),\n            'macd': compute_macd(close_prices),\n            'momentum_5d_pct': round(momentum_5d, 2),\n            'volatility_pct': round(volatility, 4),\n            'avg_volume_20d': int(sum(volumes[-20:]) / min(20, len(volumes))) if volumes else 0,\n            'trend': 'bullish' if cur > ma_20 > ma_50 else ('bearish' if cur < ma_20 < ma_50 else 'neutral')\n        }\n    except Exception as e:\n        return {'error': str(e), 'ticker': ticker}"
                },
                "outputs": {
                  "type": "object",
                  "properties": {
                    "ticker": {"type": "string"},
                    "current_price": {"type": "number"},
                    "ma_20": {"type": "number"},
                    "ma_50": {"type": "number"},
                    "rsi_14": {"type": "number"},
                    "macd": {"type": "object"},
                    "momentum_5d_pct": {"type": "number"},
                    "volatility_pct": {"type": "number"},
                    "trend": {"type": "string"}
                  }
                }
              }
