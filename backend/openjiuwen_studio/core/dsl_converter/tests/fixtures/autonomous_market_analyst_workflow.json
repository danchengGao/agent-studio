      {
        "id": "10_3a0f3f5f",
        "type": "10",
        "meta": {"position": {"x": 704, "y": 465.75}},
        "data": {
          "title": "Categorize All Results",
          "inputs": {
            "inputParameters": {
              "loop_output": {"type": "ref", "content": ["5_a4d5361d", "output"]}
            },
            "language": "python3",
            "code": "import json\n\ndef main(loop_output):\n    results = loop_output if isinstance(loop_output, list) else [loop_output]\n    buy, hold, caution = [], [], []\n    for item in results:\n        try:\n            sig = item.get('llm_agent_strategist_output', '{}')\n            if isinstance(sig, str):\n                sig = json.loads(sig)\n            ticker = item.get('ticker', item.get('items', 'UNKNOWN'))\n            cat = sig.get('final_category', 'NEUTRAL_HOLD')\n            entry = {'ticker': ticker, 'category': cat, 'confidence': sig.get('confidence_score', 0.5), 'explanation': sig.get('explanation', ''), 'recommendation': sig.get('recommendation', '')}\n            if cat == 'BUY_WATCHLIST': buy.append(entry)\n            elif cat == 'CAUTION_TRIM': caution.append(entry)\n            else: hold.append(entry)\n        except: pass\n    return {'buy_watchlist': buy, 'neutral_hold': hold, 'caution_trim': caution, 'total_analyzed': len(results)}"
          },
          "outputs": {
            "type": "object",
            "properties": {
              "buy_watchlist": {"type": "array"},
              "neutral_hold": {"type": "array"},
              "caution_trim": {"type": "array"},
              "total_analyzed": {"type": "integer"}
            }
          }
        }
      },
