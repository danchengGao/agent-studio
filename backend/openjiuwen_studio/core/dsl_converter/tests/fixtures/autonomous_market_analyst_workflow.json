              "data": {
                "title": "Fetch OHLCV Market Data",
                "inputs": {
                  "httpRequestParam": {
                    "url": {"type": "template", "content": "https://query1.finance.yahoo.com/v8/finance/chart/{{items}}?interval=1d&range=60d"},
                    "method": "GET",
