        "meta": {"position": {"x": 1624, "y": 234.25}},
        "data": {
          "title": "What-If Scenario Simulation",
          "inputs": {
            "inputParameters": {
              "ticker": {"type": "ref", "content": ["1_c5f579b8", "ticker"]},
              "user_query": {"type": "ref", "content": ["1_c5f579b8", "user_query"]}
            },
            "language": "python3",
            "code": "import re\n\ndef main(ticker, user_query):\n    pct = 10.0\n    match = re.search(r'([+-]?\\d+(?:\\.\\d+)?)\\s*%', str(user_query))\n    if match:\n        pct = float(match.group(1))\n    return {\n        'ticker': ticker,\n        'price_change_pct': pct,\n        'scenario_description': f'{ticker} moves {pct:+.1f}%',\n        'implied_new_rsi': min(100, max(0, 50 + pct * 1.5)),\n        'momentum_impact': 'strengthened' if pct > 0 else 'weakened',\n        'vol_impact': 'increased volatility expected' if abs(pct) > 5 else 'moderate volatility'\n    }"
          },
          "outputs": {
            "type": "object",
            "properties": {
              "ticker": {"type": "string"},
              "price_change_pct": {"type": "number"},
              "scenario_description": {"type": "string"}
            }
          }
        }
      },
