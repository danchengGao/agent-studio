      {
        "id": "10_41bf7ec0",
        "type": "10",
        "meta": {"position": {"x": 704, "y": 846.75}},
        "data": {
          "title": "Format Slack Daily Report",
          "inputs": {
            "inputParameters": {
              "categorized": {"type": "ref", "content": ["10_3a0f3f5f", "output"]},
              "meta_eval": {"type": "ref", "content": ["3_3bd8dd96", "output"]}
            },
            "language": "python3",
            "code": "import json\nfrom datetime import datetime\n\ndef main(categorized, meta_eval):\n    try:\n        cat = categorized if isinstance(categorized, dict) else json.loads(str(categorized))\n        meta = meta_eval if isinstance(meta_eval, dict) else json.loads(str(meta_eval))\n    except:\n        cat = {'buy_watchlist': [], 'neutral_hold': [], 'caution_trim': []}\n        meta = {'reflection': 'Analysis complete', 'system_performance': 'good'}\n    date_str = datetime.now().strftime('%Y-%m-%d')\n    msg = f'📊 *Daily Market Analysis — {date_str}*\\n\\n'\n    msg += f'🟢 *BUY WATCHLIST* ({len(cat.get(\"buy_watchlist\", []))})\\n'\n    for i in cat.get('buy_watchlist', []):\n        msg += f'  • *{i[\"ticker\"]}* ({i[\"confidence\"]:.0%}) — {i[\"explanation\"][:80]}...\\n'\n    msg += f'\\n⚪ *NEUTRAL HOLD* ({len(cat.get(\"neutral_hold\", []))})\\n'\n    for i in cat.get('neutral_hold', []):\n        msg += f'  • {i[\"ticker\"]} ({i[\"confidence\"]:.0%})\\n'\n    msg += f'\\n🔴 *CAUTION / TRIM* ({len(cat.get(\"caution_trim\", []))})\\n'\n    for i in cat.get('caution_trim', []):\n        msg += f'  • *{i[\"ticker\"]}* ({i[\"confidence\"]:.0%}) — {i[\"explanation\"][:80]}...\\n'\n    msg += f'\\n🧠 *System Reflection:* {meta.get(\"reflection\", \"\")}\\n'\n    msg += f'📈 *Market Mood:* {meta.get(\"system_performance\", \"good\").upper()}\\n'\n    return {'slack_message': msg, 'total_stocks': cat.get('total_analyzed', 0)}"
          },
          "outputs": {
            "type": "object",
            "properties": {
              "slack_message": {"type": "string"},
              "total_stocks": {"type": "integer"}
            }
          }
        }
