{
  "name": "Example n8n Workflow",
  "nodes": [
    {
      "id": "webhook_1",
      "name": "Webhook",
      "type": "n8n-nodes-base.webhook",
      "position": [250, 300],
      "parameters": {
        "path": "test-webhook",
        "httpMethod": "POST"
      }
    },
    {
      "id": "http_request_1",
      "name": "HTTP Request",
      "type": "n8n-nodes-base.httpRequest",
      "position": [450, 300],
      "parameters": {
        "url": "https://api.example.com/data",
        "method": "GET",
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "Bearer token123"
            }
          ]
        }
      }
    },
    {
      "id": "code_1",
      "name": "Process Data",
      "type": "n8n-nodes-base.code",
      "position": [650, 300],
      "parameters": {
        "code": "// Process the data\nconst items = $input.all();\nconst processed = items.map(item => ({\n  ...item,\n  processed: true\n}));\nreturn processed;"
      }
    },
    {
      "id": "if_1",
      "name": "Check Condition",
      "type": "n8n-nodes-base.if",
      "position": [850, 300],
      "parameters": {
        "conditions": {
          "boolean": [
            {
              "value1": "={{$json.processed}}",
              "value2": true
            }
          ]
        }
      }
    },
    {
      "id": "respond_1",
      "name": "Respond to Webhook",
      "type": "n8n-nodes-base.respondToWebhook",
      "position": [1050, 300],
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{$json}}"
      }
    }
  ],
  "connections": {
    "Webhook": {
      "main": [
        [
          {
            "node": "HTTP Request",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "HTTP Request": {
      "main": [
        [
          {
            "node": "Process Data",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Process Data": {
      "main": [
        [
          {
            "node": "Check Condition",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Check Condition": {
      "main": [
        [
          {
            "node": "Respond to Webhook",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "settings": {
    "timezone": "UTC"
  },
  "staticData": null,
  "tags": [],
  "triggerCount": 0,
  "updatedAt": "2024-01-01T00:00:00.000Z",
  "versionId": "1"
}
