# .env.example
# This file contains the environment variables needed to run the application.
# Copy this file to .env and fill in the appropriate values for your local environment.
# DO NOT COMMIT the .env file to version control.

# --- Application Settings ---
# Set to True for development to enable debug mode and auto-reloading
DEBUG=True

# --- Server Settings ---
HOST="0.0.0.0"
PORT=8000

# --- Database Type ---
# Type of database to use. Can be 'mysql' or 'sqlite'.
DB_TYPE="mysql"

# --- MySQL Configuration (if DB_TYPE is 'mysql') ---
DB_HOST="127.0.0.1"
DB_PORT=3306
DB_USER="root"
DB_PASSWORD=""
AGENT_DB_NAME="openjiuwen_agent"
OPS_DB_NAME="openjiuwen_ops"

# --- SQLite Configuration (if DB_TYPE is 'sqlite') ---
# These are relative to the 'backend' directory
SQLITE_DB_PATH="data/databases"
AGENT_SQLITE_DB="agent.db"
OPS_SQLITE_DB="ops.db" # Assuming ops db will also have a sqlite option

# --- DEEPSEARCH Configuration ---
DEEPSEARCH_AGENT_HOST="127.0.0.1"
DEEPSEARCH_AGENT_PORT=6000

# --- Security Settings ---
# It is strongly recommended to change this to a long, random string in production
SECRET_KEY="your-secret-key-change-in-production"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=5256000
REFRESH_TOKEN_EXPIRE_DAYS=3650

# --- CORS Settings ---
# Comma-separated list of allowed origins
ALLOWED_ORIGINS="http://localhost:3000,http://127.0.0.1:3000"

# --- Redis ---
REDIS_URL="redis://localhost:6379"

# --- LLM and External APIs ---
# Keys for large language models and other services
LLM_BASIC_BASE_URL=""
LLM_BASIC_MODEL=""
LLM_BASIC_API_KEY=""
LLM_BASIC_API_TYPE=""
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""

# --- Legacy Database Sync ---
# If True, runs the old database sync logic on startup.
# Recommended to keep this False and use Alembic for migrations.
AUTO_SYNC_DB=False
