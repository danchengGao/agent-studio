# Jiuwen Agent Studio Default Configuration
NODE_ENV=development
VITE_API_BASE_URL=/api/v1
VITE_API_PROXY_CHANGE_ORIGIN=true
VITE_API_PROXY_SECURE=false
VITE_API_PROXY_REWRITE=/api
VITE_API_PROXY_TIMEOUT=300000
VITE_API_PROMPT_LENGTH=8000
HOST=0.0.0.0
WORKER_NUM=1
DEBUG=false
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=2880
REFRESH_TOKEN_EXPIRE_DAYS=2
VITE_TOKEN_REFRESH_INTERVAL_SECONDS=600
ALLOWED_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]
LLM_SSL_VERIFY=False
VITE_PLUGIN_CONFIG_PATH=/config.json
RESTFUL_SSL_VERIFY=False
RESTFUL_SSL_CERT=False
WORKFLOW_EXECUTE_TIMEOUT=300
FORCE_DEL_WORKFLOW_STATE=True
IS_SENSITIVE=False
SSRF_PROTECT_ENABLED=False
EMBEDDING_MODEL_DIMENTION=1024
EMBED_API_BASE=""
EMBED_MODEL_NAME=""
EMBED_API_KEY=""
EMBED_TIMEOUT=5
EMBED_MAX_RETRIES=1
EMBED_SSL_VERIFY=False
EMBED_SSL_CERT=False
