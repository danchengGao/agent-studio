# openJiuwen Agent Studio Configuration
# This file contains the essential environment variables
# Copy this file to .env and modify the values according to your environment

# =============================================================================
# FRONTEND CONFIGURATION
# =============================================================================

# Node.js environment (development, production)
NODE_ENV=development

# Frontend service port
FRONTEND_PORT=3000

# API base URL for frontend to connect to backend
# Use /api/v1 for development (will be proxied by Vite)
# Use your domain/IP for production deployment
VITE_API_BASE_URL=/api/v1

# Proxy target for backend API in development
# This is where Vite will proxy API requests to
VITE_API_PROXY_TARGET=http://localhost:8000/

# Proxy configuration options
VITE_API_PROXY_CHANGE_ORIGIN=true
VITE_API_PROXY_SECURE=false
VITE_API_PROXY_REWRITE=/api
VITE_API_PROXY_TIMEOUT=300000
# Maximum prompt length for user and system prompts in workflow components
VITE_API_PROMPT_LENGTH=8000

# the environment variables are written by build_ssl_files.sh
SSL_PASSWORD=

# User Auth Type
# If True, enables the new authentication system with registration and password management.
# If False, uses the original simple login system.
VITE_ENABLE_NEW_AUTH=False

# =============================================================================
# BACKEND CONFIGURATION
# =============================================================================

# Backend service port
BACKEND_PORT=8000

# Host binding (0.0.0.0 for all interfaces)
HOST=0.0.0.0

# Worker num
WORKER_NUM=1

# Debug mode (false for production)
DEBUG=false

# Secret key for JWT tokens and encryption (CHANGE IN PRODUCTION!)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-secret-key-change-in-production

# JWT algorithm
ALGORITHM=HS256

# JWT token expiration time in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=2880

# JWT refresh token expiration time in days
REFRESH_TOKEN_EXPIRE_DAYS=2

# Frontend token refresh interval in seconds (default: 600)
VITE_TOKEN_REFRESH_INTERVAL_SECONDS=600

# Allowed origins for CORS (JSON array format)
ALLOWED_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# Optional develop or product.
# In product mode, the environment variable SERVER_AES_MASTER_KEY_ENV must be set to ensure that sensitive information not persisted to disk
SERVICE_MODE=develop

CODE_SANDBOX_URL=""

# llm ssl verify
LLM_SSL_VERIFY=False
# api_key encrypt key, only takes effect when SERVICE_MODE is set to develop.
# require 32-byte (256-bit) AES key
SERVER_AES_MASTER_KEY=

# AES key Encoded in base64, used in product mode.
SERVER_AES_MASTER_KEY_ENV=

FORCE_DEL_WORKFLOW_STATE=True
IS_SENSITIVE=False
SSRF_PROTECT_ENABLED=False

# Runtime server configuration
RUNTIME_HOST=localhost
RUNTIME_PORT=8186

# Deepsearch config
DEEPSEARCH_AGENT_HOST=localhost
DEEPSEARCH_AGENT_PORT=6000

# Workflow Timeout
WORKFLOW_EXECUTE_TIMEOUT=300

# System admin
SYSTEM_ADMIN_TOKEN=""

# =============================================================================
# DB/STORE CONFIGURATION
# =============================================================================

# Database type (mysql/sqlite)
DB_TYPE=sqlite

# MySQL database configuration
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=root
OPS_DB_NAME=openjiuwen_ops
AGENT_DB_NAME=openjiuwen_agent

# SQLite configuration (used when DB_TYPE=sqlite)
SQLITE_DB_PATH=data/databases
OPS_SQLITE_DB=ops.db
AGENT_SQLITE_DB=agent.db

# MinIO database configuration
MINIO_HOST=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=False
MINIO_BUCKET=jiuwen-bucket

# Redis configuration
ENABLE_REDIS_CHECKPOINT=False
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# Index manager type: chroma or milvus
INDEX_MANAGER_TYPE="chroma"

# Mivlus Configuration
MILVUS_HOST="jiuwen-milvus-standalone"
MILVUS_PORT="19530"
MILVUS_COLLECTION_NAME="memory_vector"
MILVUS_TOKEN=""
EMBEDDING_MODEL_DIMENTION=1024

# --- Legacy Database Sync ---
# If True, runs the old database sync logic on startup.
# Recommended to keep this False and use Alembic for migrations.
AUTO_SYNC_DB=False

MEMORY_DATA_PATH=memory-data

# =============================================================================
# PLUGIN SERVICE CONFIGURATION
# =============================================================================

# Base URL for plugin services, default is NULL
VITE_PLUGIN_SERVICE_URL=""
# Plugin configuration file path, default config_path is ./frontend/public/config.json
VITE_PLUGIN_CONFIG_PATH=/config.json

# Restfulapi need check ssl verify
RESTFUL_SSL_VERIFY=False
RESTFUL_SSL_CERT=False
# Custom auth function, format: /path/custom_auth.py:auth
AUTH_FUNCTION=

# =============================================================================
# E-mail  CONFIGURATION
# =============================================================================
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
SMTP_ALIAS=openJiuwen

# =============================================================================
# HUAWEICLOUD  CONFIGURATION
# =============================================================================

# --- KMS Config for Secret Protection
HUAWEICLOUD_KMS_ENABLED=False
# 华为云IAM配置
HUAWEICLOUD_USERNAME=your_username
HUAWEICLOUD_DOMAIN_NAME=your_domain
HUAWEICLOUD_IAM_ENDPOINT=https://iam.myhuaweicloud.com

# 华为云项目配置
HUAWEICLOUD_PROJECT_NAME=ap-southeast-1
HUAWEICLOUD_PROJECT_ID=your_project_id
HUAWEICLOUD_REGION=ap-southeast-1

# 华为云KMS配置
HUAWEICLOUD_KMS_KEY_ID=your_kms_key_id
HUAWEICLOUD_KMS_ENDPOINT=
ENCRYPTED_ROOT_KEY=your_encrypted_root_key
HUAWEICLOUD_KMS_ENCRYPTION_ALGORITHM=RSAES_OAEP_SHA_256

# =============================================================================
# OBS config 
# =============================================================================
OBS_ACCESS_KEY_ID=
OBS_SECRET_ACCESS_KEY=
OBS_SERVER=
OBS_REGION=
OBS_BUCKET=

# =============================================================================
# SYSTEM PROXY CONFIGURATION
# =============================================================================
NO_PROXY=localhost,127.0.0.1,::1